rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsResource() {
      return isSignedIn() && resource.data.uid == request.auth.uid;
    }

    function incomingBelongsToUser() {
      return isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, delete: if ownsResource();
      allow create, update: if incomingBelongsToUser();
    }
  }
}
